{
  "name": "robot-web",
  "private": true,
  "workspaces": [
    "apps/frontend"
  ],
  "scripts": {
    "build": "npm run build --workspace=apps/frontend",
    "start": "concurrently --names \"backend,frontend\" --prefix-colors \"cyan,magenta\" \"npm run prod:backend\" \"npm run prod:frontend\"",
    "prod:backend": "cd apps/backend && uv run uvicorn main:app",
    "prod:frontend": "npm run server --workspace=apps/frontend",
    "dev": "concurrently --names \"backend,frontend\" --prefix-colors \"cyan,magenta\" \"npm run dev:backend\" \"npm run dev --workspace=apps/frontend\"",
    "dev:backend": "cd apps/backend && uv run uvicorn main:app --reload",
    "dev:frontend": "npm run dev --workspace=apps/frontend"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}